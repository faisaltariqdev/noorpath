{
  "redirects": [
    {
      "source": "/quran-academy-landing.html",
      "destination": "/online-quran-classes",
      "permanent": true
    },
    {
      "source": "/courses/index.html",
      "destination": "/courses",
      "permanent": true
    },
    {
      "source": "/locations/index.html",
      "destination": "/locations",
      "permanent": true
    },
    {
      "source": "/online-quran-classes.html",
      "destination": "/online-quran-classes",
      "permanent": true
    },
    {
      "source": "/learn-quran-online.html",
      "destination": "/learn-quran-online",
      "permanent": true
    },
    {
      "source": "/best-online-quran-classes-for-kids.html",
      "destination": "/best-online-quran-classes-for-kids",
      "permanent": true
    },
    {
      "source": "/online-quran-teaching-jobs.html",
      "destination": "/online-quran-teaching-jobs",
      "permanent": true
    },
    {
      "source": "/online-quran-classes-for-adults.html",
      "destination": "/online-quran-classes-for-adults",
      "permanent": true
    },
    {
      "source": "/female-quran-teacher-online.html",
      "destination": "/female-quran-teacher-online",
      "permanent": true
    },
    {
      "source": "/pricing.html",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/privacy-policy.html",
      "destination": "/privacy-policy",
      "permanent": true
    },
    {
      "source": "/terms-of-service.html",
      "destination": "/terms-of-service",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "noorpath.online" }],
      "destination": "https://www.noorpath.online/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/courses", "destination": "/courses/index.html" },
    { "source": "/locations", "destination": "/locations/index.html" },
    { "source": "/online-quran-classes", "destination": "/online-quran-classes.html" },
    { "source": "/learn-quran-online", "destination": "/learn-quran-online.html" },
    { "source": "/best-online-quran-classes-for-kids", "destination": "/best-online-quran-classes-for-kids.html" },
    { "source": "/online-quran-teaching-jobs", "destination": "/online-quran-teaching-jobs.html" },
    { "source": "/online-quran-classes-for-adults", "destination": "/online-quran-classes-for-adults.html" },
    { "source": "/female-quran-teacher-online", "destination": "/female-quran-teacher-online.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/terms-of-service", "destination": "/terms-of-service.html" }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/llms.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ]
}
